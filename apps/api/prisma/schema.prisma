generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// CUSTOMERS (auth de clientes)
// ===========================

model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  isAutoCreated Boolean @default(false) // true si se creó al reservar
  reservations Reservation[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ===========================
// ZONES & TABLES
// ===========================

model Zone {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  mapWidth    Int      @default(720)
  mapHeight   Int      @default(520)
  furniture   Json?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  tables      Table[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Table {
  id           String   @id @default(cuid())
  code         String
  label        String
  seats        Int
  posX         Float
  posY         Float
  width        Float    @default(80)
  height       Float    @default(65)
  shape        String   @default("rect")
  adjacentIds  String[]
  isActive     Boolean  @default(true)
  zoneId       String
  zone         Zone     @relation(fields: [zoneId], references: [id])
  reservations ReservationTable[]

  @@unique([zoneId, code])
  @@index([zoneId])
}

// ===========================
// RESERVATIONS
// ===========================

model Reservation {
  id               String            @id @default(cuid())
  date             DateTime          @db.Date
  hour             String
  people           Int
  status           ReservationStatus @default(CONFIRMED)
  customerName     String
  customerEmail    String
  customerPhone    String
  eventType        String?
  notes            String?
  isCombined       Boolean           @default(false)
  isSpecialRequest Boolean           @default(false)
  staffNotes       String?
  cancelToken      String?           @unique

  // Link to customer account (nullable for backwards compat)
  customerId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id])

  tables           ReservationTable[]
  emails           EmailLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cancelledAt      DateTime?

  @@index([date, hour])
  @@index([customerEmail])
  @@index([cancelToken])
  @@index([customerId])
}

model ReservationTable {
  reservationId String
  tableId       String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table         Table       @relation(fields: [tableId], references: [id])
  @@id([reservationId, tableId])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
  COMPLETED
  NO_SHOW
}

// ===========================
// EMAIL LOG
// ===========================

model EmailLog {
  id            String       @id @default(cuid())
  type          String
  to            String
  subject       String
  sentAt        DateTime     @default(now())
  status        String       @default("sent")
  error         String?
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])
}

// ===========================
// GAMES
// ===========================

model Game {
  id          String  @id @default(cuid())
  externalId  Int?    @unique
  name        String
  description String?
  imageUrl    String?
  playersMin  Int
  playersMax  Int
  playersBest Int?
  durationMin Int
  durationMax Int
  ageMin      Int     @default(8)
  difficulty  Int     @default(0)
  isAvailable Boolean @default(true)
  location    String?
  categories  GameCategory[]
  mechanics   GameMechanic[]
  types       GameType[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([name])
}

model Category {
  id    Int            @id
  name  String
  games GameCategory[]
}

model Mechanic {
  id    Int            @id
  name  String
  games GameMechanic[]
}

model Type {
  id    Int        @id
  name  String
  games GameType[]
}

model GameCategory {
  gameId     String
  categoryId Int
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])
  @@id([gameId, categoryId])
}

model GameMechanic {
  gameId     String
  mechanicId Int
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  mechanic   Mechanic @relation(fields: [mechanicId], references: [id])
  @@id([gameId, mechanicId])
}

model GameType {
  gameId String
  typeId Int
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  type   Type @relation(fields: [typeId], references: [id])
  @@id([gameId, typeId])
}

// ===========================
// STAFF USERS
// ===========================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum UserRole {
  ADMIN
  STAFF
}
